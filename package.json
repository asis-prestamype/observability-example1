{
  "name": "koa-observability-api",
  "version": "1.0.0",
  "description": "Koa API with MongoDB and AWS Distro OpenTelemetry observability",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "docker:build": "docker build --target production -t koa-observability-api .",
    "docker:build:dev": "docker build --target development -t koa-observability-api:dev .",
    "docker:build:prod": "docker build --target production -t koa-observability-api:prod .",
    "docker:up": "docker-compose up -d",
    "docker:up:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose down",
    "docker:down:prod": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:prod": "docker-compose -f docker-compose.prod.yml logs -f",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "koa": "^2.15.0",
    "koa-router": "^12.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-cors": "^0.0.16",
    "koa-helmet": "^7.0.2",
    "koa-logger": "^3.2.1",
    "mongodb": "^6.3.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/auto-instrumentations-node": "^0.40.3",
    "@opentelemetry/exporter-jaeger": "^1.18.1",
    "@opentelemetry/instrumentation-koa": "^0.37.0",
    "@opentelemetry/instrumentation-mongodb": "^0.39.0",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/semantic-conventions": "^1.18.1"
  },
  "devDependencies": {
    "@types/koa": "^2.14.0",
    "@types/koa-router": "^7.4.8",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-cors": "^0.0.5",
    "@types/koa-logger": "^3.1.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "koa",
    "mongodb",
    "opentelemetry",
    "jaeger",
    "observability",
    "docker",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT"
}